# ─── LiqPay ───────────────────────────────────────────────
# Get keys at: https://www.liqpay.ua/en/authorization/data
LIQPAY_PUBLIC_KEY=sandbox_...
LIQPAY_PRIVATE_KEY=sandbox_...

# ─── Resend (email) ───────────────────────────────────────
# Get key at: https://resend.com/api-keys
RESEND_API_KEY=re_...
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── App ──────────────────────────────────────────────────
# Your production domain (used in emails and LiqPay callbacks)
APP_URL=https://тривога.net

# ─── Admin panel ──────────────────────────────────────────
# Password for GET /api/admin/orders
ADMIN_PASSWORD=choose_strong_password
