# LiqPay credentials — get them at https://www.liqpay.ua/en/authorization/data
# ⚠️  VITE_ vars are bundled into the client bundle (visible in browser).
# For production, generate the signature server-side and remove VITE_LIQPAY_PRIVATE_KEY.
VITE_LIQPAY_PUBLIC_KEY=your_public_key_here
VITE_LIQPAY_PRIVATE_KEY=your_private_key_here
