# ─── API ─────────────────────────────────────────────────
# Proxy prefix — Vite dev server proxies /api → backend
VITE_API_BASE_URL=/api

# Site host for the multitenant backend (used in Vite proxy headers)
VITE_SITE_HOST=tryvoga.net

# ─── Google Analytics 4 ─────────────────────────────────
# VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Payments ───────────────────────────────────────────
# Set to 1 to route checkout through the Hutko test endpoint
# (Fondy public sandbox merchant — no real charge). Omit for live.
# VITE_HUTKO_TEST=1
